# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=language_learning
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRATION=30d

# Google OAuth (placeholders)
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID_PLACEHOLDER
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET_PLACEHOLDER
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4o-mini

# Web Scraping
SCRAPING_DELAY_MS=1000

# Topic sources
REDDIT_DEFAULT_SUBREDDITS=languagelearning,technology,worldnews
REDDIT_FETCH_LIMIT=10
REDDIT_USER_AGENT=language-learning-backend/1.0

# Background refresh jobs
ENABLE_CONTENT_REFRESH=false

# TypeORM behavior
TYPEORM_SYNCHRONIZE=false
TYPEORM_RUN_MIGRATIONS=false

# Server
NODE_ENV=development
PORT=3000
